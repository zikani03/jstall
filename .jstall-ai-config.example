# Example .jstall-ai-config file
# Place this file in your current directory or home directory (~/)

# Provider: local (OpenAI-compatible server like llama-server)
provider=local

# Local server host (default: http://127.0.0.1:8080)
local.host=http://127.0.0.1:8080

# Auto-launch llama-server with a HuggingFace model:
# Good quality (9B, ~9.5GB, needs 12GB+ RAM):
local.llama-server-model=AaryanK/Qwen3.5-9B-GGUF:Q8_0
# Smaller/faster alternative (4B, ~4.5GB):
#local.llama-server-model=AaryanK/Qwen3.5-4B-GGUF:Q8_0
#api.key=your-api-key-here